# WiseWallet — Render Web Service environment variables (TEMPLATE)
#
# Setup:
#   1. Copy:  cp .env.render.example .env.render
#   2. Fill in real values (or run: npm run render:env from local .env files)
#   3. Render Dashboard → wisewallet-api → Environment → paste KEY=value lines
#
# Safe to commit — no real secrets. Do NOT put secrets in this file.

NODE_ENV=production

# Neon PostgreSQL — https://neon.tech
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# Generate: openssl rand -base64 32
JWT_SECRET=your-long-random-jwt-secret

# Vercel frontend URL — use localhost until Vercel deploy, then your *.vercel.app URL
WEB_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# Google OAuth — localhost for dev; after Render deploy use your *.onrender.com URL
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxx
GOOGLE_CALLBACK_URL=http://localhost:8080/api/auth/google/callback

# Groq AI — https://console.groq.com
GROQ_API_KEY=gsk_xxxx

# Brevo email — https://app.brevo.com/settings/keys/api
BREVO_API_KEY=xkeysib-xxxx
EMAIL_FROM=WiseWallet <noreply@yourdomain.com>

# Generate: openssl rand -hex 24 (must match in notification + worker)
INTERNAL_SERVICE_SECRET=your-internal-service-secret

# ArcJet — https://app.arcjet.com
ARCJET_KEY=ajkey_xxxx

# Bundled backend — DO NOT change (all services run in same Render container)
NOTIFICATION_SERVICE_URL=http://localhost:4005

# Inngest Cloud — https://app.inngest.com (optional, for cron + scheduled emails)
# Serve URL: https://wisewallet-api.onrender.com/api/inngest
# INNGEST_EVENT_KEY=
# INNGEST_SIGNING_KEY=
