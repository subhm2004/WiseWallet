# Notification Service - Emails via Brevo
# Copy: cp .env.example .env

# Neon PostgreSQL (email logs stored here)
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/wisewallet?sslmode=require

# JWT (must match auth-service — for user email history)
JWT_SECRET=your-super-secret-jwt-key-change-this

# Brevo - https://app.brevo.com/settings/keys/api
BREVO_API_KEY=xkeysib-your-brevo-api-key

# Verified sender in Brevo (Senders & Domains)
EMAIL_FROM=WiseWallet <noreply@yourdomain.com>

# Internal key (must match worker-service)
INTERNAL_SERVICE_SECRET=your-internal-service-secret
