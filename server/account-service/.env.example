# Account Service
# Copy: cp .env.example .env

# Neon PostgreSQL
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/wisewallet?sslmode=require

# JWT (must match auth-service)
JWT_SECRET=your-super-secret-jwt-key-change-this

# ArcJet - rate limiting (10 creates/hour per user)
# Same key from https://app.arcjet.com
ARCJET_KEY=ajkey_xxxxxxxx
