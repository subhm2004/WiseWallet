# Worker Service - Inngest background jobs
# Copy: cp .env.example .env

# Neon PostgreSQL
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/wisewallet?sslmode=require

# Groq API - monthly AI insights
GROQ_API_KEY=your-groq-api-key

# Internal key (must match notification-service)
INTERNAL_SERVICE_SECRET=your-internal-service-secret

# Notification service URL (optional, default: http://localhost:4005)
NOTIFICATION_SERVICE_URL=http://localhost:4005

# Frontend URL for email CTA links
FRONTEND_URL=http://localhost:3000

# Inngest (optional — only needed for production/cloud)
# Local dev uses Inngest Dev Server — no key required
# INNGEST_EVENT_KEY=
# INNGEST_SIGNING_KEY=

# Inngest Dev Server URL (optional, auto-detected in dev)
# INNGEST_DEV=http://localhost:8288
