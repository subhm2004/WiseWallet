# API Gateway
# Copy: cp .env.example .env

# Allowed frontend origin for CORS
WEB_URL=http://localhost:3000

# ArcJet - https://app.arcjet.com (shield + bot detection)
ARCJET_KEY=ajkey_xxxxxxxx

# Optional — microservice URLs (default: http://localhost:PORT for local dev)
# Set these when each service runs on its own host (e.g. separate Render services).
# AUTH_SERVICE_URL=http://localhost:4001
# ACCOUNT_SERVICE_URL=http://localhost:4002
# TRANSACTION_SERVICE_URL=http://localhost:4003
# BUDGET_SERVICE_URL=http://localhost:4004
# NOTIFICATION_SERVICE_URL=http://localhost:4005
# WORKER_SERVICE_URL=http://localhost:4006

# Optional
NODE_ENV=development
